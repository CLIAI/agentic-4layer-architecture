{
  "_comment": "Components live in plugins/four-layer-architecture/. For full plugin loading (commands/agents/skills + hooks), launch Claude Code with: claude --plugin-dir ./plugins/four-layer-architecture. These hook entries only keep guardrails active when working in the repo without --plugin-dir.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash plugins/four-layer-architecture/hooks/validate-no-force-push.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash plugins/four-layer-architecture/hooks/check-frontmatter.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash plugins/four-layer-architecture/hooks/check-prerequisites.sh"
          }
        ]
      }
    ]
  }
}
